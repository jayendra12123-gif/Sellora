# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sellora?retryWrites=true&w=majority

# Server
PORT=5000

# Sessions & security
SESSION_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
BCRYPT_SALT_ROUNDS=12

# Caching (ms)
PRODUCT_CACHE_MS=30000
ORDER_STATS_CACHE_MS=60000

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxx

# Redis (for Redlock)
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
STOCK_LOCK_TTL_MS=600000
